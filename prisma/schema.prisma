generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int    @id @default(autoincrement())
  firstName     String @map("first_name")
  lastName      String @map("last_name")
  profileImgURL String? @map("profile_img_url")
  email         String @unique
  password      String
  salt          String

  @@map("users")
}